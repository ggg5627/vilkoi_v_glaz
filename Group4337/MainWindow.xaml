<Window x:Class="Group4337.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Инструментальные Средства Разработки Программного Обеспечения" 
        Height="800" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Студенты группы 4337"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="16" 
                   FontWeight="Bold"
                   Grid.Row="0" 
                   Margin="0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                   Text="Гайфуллина Раида" 
                   FontSize="18" 
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,12"/>

                <TextBlock Grid.Row="1" 
                   Text="18 лет" 
                   FontSize="15"
                   Foreground="#34495E"
                   Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" 
                   Text="Группа 4337" 
                   FontSize="15"
                   Foreground="#34495E"/>
                

                <Button Grid.Row="25" 
                        Content="📥 Импорт данных" 
                        HorizontalAlignment="Left" 
                        VerticalAlignment="Center"
                        Margin="15,8,0,4"
                        Width="150"
                        Background="#27AE60"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnImport_Click"/>

                <Button Grid.Row="26" 
                        Content="📤 Экспорт в Excel" 
                        HorizontalAlignment="Left" 
                        VerticalAlignment="Center"
                        Margin="15,4,0,8"
                        Width="150"
                        Background="#2980B9"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnExport_Click"/>

                <Button Grid.Row="27" 
        Content="📥 Импорт JSON данных" 
        HorizontalAlignment="Left" 
        VerticalAlignment="Center"
        Margin="15,8,0,4"
        Width="180"
        Background="#E67E22"
        Foreground="White"
        FontWeight="Bold"
        Click="BtnImportJson_Click"/>

                <Button Grid.Row="28" 
        Content="📤 Экспорт в Word" 
        HorizontalAlignment="Left" 
        VerticalAlignment="Center"
        Margin="15,4,0,8"
        Width="180"
        Background="#8E44AD"
        Foreground="White"
        FontWeight="Bold"
        Click="BtnExportWord_Click"/>

            </Grid>
        </ScrollViewer>
    </Grid>
</Window>